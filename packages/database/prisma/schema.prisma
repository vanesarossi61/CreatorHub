// CreatorHub — Prisma Schema
// Base de datos: PostgreSQL
// Genera el client con: npx prisma generate
// Aplica migraciones con: npx prisma migrate dev

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================
// AUTH & USERS
// =============================

model User {
  id             String    @id @default(cuid())
  clerkId        String    @unique @map("clerk_id")
  email          String    @unique
  firstName      String?   @map("first_name")
  lastName       String?   @map("last_name")
  avatarUrl      String?   @map("avatar_url")
  type           UserType
  onboardingDone Boolean   @default(false) @map("onboarding_done")
  isActive       Boolean   @default(true) @map("is_active")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  // Relations
  creator        Creator?
  brand          Brand?
  agency         Agency?
  notifications  Notification[]
  sentMessages   Message[]      @relation("SentMessages")
  receivedMessages Message[]    @relation("ReceivedMessages")

  @@map("users")
}

enum UserType {
  CREATOR
  BRAND
  AGENCY
}

// =============================
// CREATOR PROFILE
// =============================

model Creator {
  id              String   @id @default(cuid())
  userId          String   @unique @map("user_id")
  displayName     String   @map("display_name")
  bio             String?  @db.Text
  slug            String   @unique
  category        CreatorCategory
  country         String?  @db.VarChar(2) // ISO 3166-1 alpha-2
  city            String?
  languages       String[] // e.g. ["es", "en"]
  website         String?
  avatarKey       String?  @map("avatar_key") // MinIO object key
  bannerKey       String?  @map("banner_key")
  isVerified      Boolean  @default(false) @map("is_verified")
  isAvailable     Boolean  @default(true) @map("is_available")
  hourlyRateMin   Decimal? @map("hourly_rate_min") @db.Decimal(10, 2)
  hourlyRateMax   Decimal? @map("hourly_rate_max") @db.Decimal(10, 2)
  totalEarnings   Decimal  @default(0) @map("total_earnings") @db.Decimal(12, 2)
  avgRating       Decimal  @default(0) @map("avg_rating") @db.Decimal(3, 2)
  totalReviews    Int      @default(0) @map("total_reviews")
  completedDeals  Int      @default(0) @map("completed_deals")
  responseTime    Int?     @map("response_time") // avg hours to respond
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Relations
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  socialAccounts  SocialAccount[]
  portfolioItems  PortfolioItem[]
  skills          CreatorSkill[]
  applications    Application[]
  deals           Deal[]         @relation("CreatorDeals")
  reviews         Review[]       @relation("ReviewsReceived")
  payouts         Payout[]

  @@index([category])
  @@index([country])
  @@index([isAvailable, isVerified])
  @@index([avgRating(sort: Desc)])
  @@index([slug])
  @@map("creators")
}

enum CreatorCategory {
  STREAMER
  YOUTUBER
  TIKTOKER
  INSTAGRAMMER
  PODCASTER
  BLOGGER
  DESIGNER
  VIDEO_EDITOR
  PHOTOGRAPHER
  MUSICIAN
  OTHER
}

model SocialAccount {
  id           String         @id @default(cuid())
  creatorId    String         @map("creator_id")
  platform     SocialPlatform
  username     String
  profileUrl   String         @map("profile_url")
  followers    Int            @default(0)
  isVerified   Boolean        @default(false) @map("is_verified")
  connectedAt  DateTime       @default(now()) @map("connected_at")

  creator      Creator        @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@unique([creatorId, platform])
  @@map("social_accounts")
}

enum SocialPlatform {
  TWITCH
  YOUTUBE
  TIKTOK
  INSTAGRAM
  TWITTER
  KICK
  DISCORD
  SPOTIFY
  LINKEDIN
  OTHER
}

model PortfolioItem {
  id          String   @id @default(cuid())
  creatorId   String   @map("creator_id")
  title       String
  description String?  @db.Text
  mediaKey    String   @map("media_key") // MinIO object key
  mediaType   MediaType @map("media_type")
  thumbnailKey String? @map("thumbnail_key")
  externalUrl  String? @map("external_url")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")

  creator     Creator  @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@index([creatorId, sortOrder])
  @@map("portfolio_items")
}

enum MediaType {
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
  LINK
}

model CreatorSkill {
  id        String  @id @default(cuid())
  creatorId String  @map("creator_id")
  skillId   String  @map("skill_id")

  creator   Creator @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  skill     Skill   @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([creatorId, skillId])
  @@map("creator_skills")
}

model Skill {
  id       String         @id @default(cuid())
  name     String         @unique
  slug     String         @unique
  category String?

  creators CreatorSkill[]

  @@map("skills")
}

// =============================
// BRAND PROFILE
// =============================

model Brand {
  id            String   @id @default(cuid())
  userId        String   @unique @map("user_id")
  companyName   String   @map("company_name")
  slug          String   @unique
  description   String?  @db.Text
  website       String?
  logoKey       String?  @map("logo_key") // MinIO object key
  industry      String?
  companySize   CompanySize? @map("company_size")
  country       String?  @db.VarChar(2)
  isVerified    Boolean  @default(false) @map("is_verified")
  totalSpent    Decimal  @default(0) @map("total_spent") @db.Decimal(12, 2)
  avgRating     Decimal  @default(0) @map("avg_rating") @db.Decimal(3, 2)
  totalReviews  Int      @default(0) @map("total_reviews")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaigns     Campaign[]
  reviews       Review[]   @relation("ReviewsGiven")

  @@index([slug])
  @@index([industry])
  @@map("brands")
}

enum CompanySize {
  SOLO        // 1 person
  SMALL       // 2-10
  MEDIUM      // 11-50
  LARGE       // 51-200
  ENTERPRISE  // 200+
}

// =============================
// AGENCY (OPTIONAL MULTI-CREATOR MANAGEMENT)
// =============================

model Agency {
  id            String   @id @default(cuid())
  userId        String   @unique @map("user_id")
  agencyName    String   @map("agency_name")
  slug          String   @unique
  description   String?  @db.Text
  website       String?
  logoKey       String?  @map("logo_key")
  country       String?  @db.VarChar(2)
  isVerified    Boolean  @default(false) @map("is_verified")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([slug])
  @@map("agencies")
}

// =============================
// CAMPAIGNS & DEALS
// =============================

model Campaign {
  id              String         @id @default(cuid())
  brandId         String         @map("brand_id")
  title           String
  slug            String         @unique
  description     String         @db.Text
  brief           String?        @db.Text // detailed brief for creators
  category        CreatorCategory? // target creator category
  budget          Decimal        @db.Decimal(12, 2)
  budgetSpent     Decimal        @default(0) @map("budget_spent") @db.Decimal(12, 2)
  currency        String         @default("USD") @db.VarChar(3)
  dealType        DealType       @map("deal_type")
  status          CampaignStatus @default(DRAFT)
  visibility      CampaignVisibility @default(PUBLIC)
  maxCreators     Int?           @map("max_creators")
  startDate       DateTime?      @map("start_date")
  endDate         DateTime?      @map("end_date")
  applicationDeadline DateTime?  @map("application_deadline")
  requirements    Json?          // flexible requirements: { minFollowers, platforms, etc. }
  deliverables    Json?          // what creator must deliver: { posts, videos, etc. }
  tags            String[]
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  // Relations
  brand           Brand          @relation(fields: [brandId], references: [id], onDelete: Cascade)
  applications    Application[]
  deals           Deal[]

  @@index([brandId])
  @@index([status, visibility])
  @@index([category])
  @@index([dealType])
  @@index([applicationDeadline])
  @@index([slug])
  @@map("campaigns")
}

enum DealType {
  FIXED_PRICE   // precio fijo por entregable
  HOURLY        // por hora
  REVENUE_SHARE // % de revenue
  PRODUCT_ONLY  // solo producto, sin pago
  HYBRID        // combinacion
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum CampaignVisibility {
  PUBLIC    // visible en explore
  PRIVATE   // solo por invitacion
  UNLISTED  // con link directo
}

model Application {
  id            String            @id @default(cuid())
  campaignId    String            @map("campaign_id")
  creatorId     String            @map("creator_id")
  status        ApplicationStatus @default(PENDING)
  coverLetter   String?           @map("cover_letter") @db.Text
  proposedRate  Decimal?          @map("proposed_rate") @db.Decimal(10, 2)
  proposedTerms String?           @map("proposed_terms") @db.Text
  attachmentKeys String[]        @map("attachment_keys") // MinIO object keys
  rejectionReason String?        @map("rejection_reason")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")

  // Relations
  campaign      Campaign          @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  creator       Creator           @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  deal          Deal?

  @@unique([campaignId, creatorId]) // one application per creator per campaign
  @@index([status])
  @@map("applications")
}

enum ApplicationStatus {
  PENDING
  SHORTLISTED
  ACCEPTED
  REJECTED
  WITHDRAWN
}

model Deal {
  id              String     @id @default(cuid())
  campaignId      String     @map("campaign_id")
  creatorId       String     @map("creator_id")
  applicationId   String?    @unique @map("application_id")
  status          DealStatus @default(NEGOTIATION)
  agreedRate      Decimal    @map("agreed_rate") @db.Decimal(10, 2)
  currency        String     @default("USD") @db.VarChar(3)
  terms           String?    @db.Text
  startDate       DateTime?  @map("start_date")
  endDate         DateTime?  @map("end_date")
  completedAt     DateTime?  @map("completed_at")
  cancelledAt     DateTime?  @map("cancelled_at")
  cancellationReason String? @map("cancellation_reason")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  // Relations
  campaign        Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  creator         Creator      @relation("CreatorDeals", fields: [creatorId], references: [id], onDelete: Cascade)
  application     Application? @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  deliverables    Deliverable[]
  milestones      Milestone[]
  payouts         Payout[]

  @@index([campaignId])
  @@index([creatorId])
  @@index([status])
  @@map("deals")
}

enum DealStatus {
  NEGOTIATION
  ACTIVE
  IN_PROGRESS
  IN_REVIEW
  COMPLETED
  CANCELLED
  DISPUTED
}

// =============================
// DELIVERABLES & MILESTONES
// =============================

model Deliverable {
  id            String            @id @default(cuid())
  dealId        String            @map("deal_id")
  title         String
  description   String?           @db.Text
  type          DeliverableType
  status        DeliverableStatus @default(PENDING)
  dueDate       DateTime?         @map("due_date")
  submittedAt   DateTime?         @map("submitted_at")
  approvedAt    DateTime?         @map("approved_at")
  submissionUrl String?           @map("submission_url")
  submissionKey String?           @map("submission_key") // MinIO
  feedback      String?           @db.Text
  sortOrder     Int               @default(0) @map("sort_order")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")

  deal          Deal              @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealId, sortOrder])
  @@index([status])
  @@map("deliverables")
}

enum DeliverableType {
  VIDEO
  POST
  STORY
  REEL
  STREAM
  BLOG_POST
  PHOTO_SET
  REVIEW
  OTHER
}

enum DeliverableStatus {
  PENDING
  IN_PROGRESS
  SUBMITTED
  REVISION_REQUESTED
  APPROVED
  REJECTED
}

model Milestone {
  id          String          @id @default(cuid())
  dealId      String          @map("deal_id")
  title       String
  description String?         @db.Text
  amount      Decimal         @db.Decimal(10, 2)
  currency    String          @default("USD") @db.VarChar(3)
  status      MilestoneStatus @default(PENDING)
  dueDate     DateTime?       @map("due_date")
  paidAt      DateTime?       @map("paid_at")
  sortOrder   Int             @default(0) @map("sort_order")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  deal        Deal            @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealId, sortOrder])
  @@map("milestones")
}

enum MilestoneStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  PAID
  CANCELLED
}

// =============================
// PAYMENTS
// =============================

model Payout {
  id              String       @id @default(cuid())
  creatorId       String       @map("creator_id")
  dealId          String       @map("deal_id")
  amount          Decimal      @db.Decimal(12, 2)
  currency        String       @default("USD") @db.VarChar(3)
  platformFee     Decimal      @default(0) @map("platform_fee") @db.Decimal(10, 2)
  netAmount       Decimal      @map("net_amount") @db.Decimal(12, 2)
  status          PayoutStatus @default(PENDING)
  stripePaymentId String?      @map("stripe_payment_id")
  paidAt          DateTime?    @map("paid_at")
  failedAt        DateTime?    @map("failed_at")
  failureReason   String?      @map("failure_reason")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  creator         Creator      @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  deal            Deal         @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([creatorId])
  @@index([dealId])
  @@index([status])
  @@map("payouts")
}

enum PayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
}

// =============================
// REVIEWS
// =============================

model Review {
  id          String   @id @default(cuid())
  creatorId   String   @map("creator_id")
  brandId     String   @map("brand_id")
  dealId      String   @map("deal_id")
  rating      Int      // 1-5
  title       String?
  comment     String?  @db.Text
  isPublic    Boolean  @default(true) @map("is_public")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  creator     Creator  @relation("ReviewsReceived", fields: [creatorId], references: [id], onDelete: Cascade)
  brand       Brand    @relation("ReviewsGiven", fields: [brandId], references: [id], onDelete: Cascade)

  @@unique([dealId]) // one review per deal
  @@index([creatorId, rating])
  @@index([brandId])
  @@map("reviews")
}

// =============================
// MESSAGING
// =============================

model Conversation {
  id           String    @id @default(cuid())
  dealId       String?   @map("deal_id")
  isArchived   Boolean   @default(false) @map("is_archived")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  participants ConversationParticipant[]
  messages     Message[]

  @@map("conversations")
}

model ConversationParticipant {
  id              String       @id @default(cuid())
  conversationId  String       @map("conversation_id")
  userId          String       @map("user_id")
  lastReadAt      DateTime?    @map("last_read_at")
  joinedAt        DateTime     @default(now()) @map("joined_at")

  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@map("conversation_participants")
}

model Message {
  id              String       @id @default(cuid())
  conversationId  String       @map("conversation_id")
  senderId        String       @map("sender_id")
  recipientId     String?      @map("recipient_id") // null = broadcast to conversation
  content         String       @db.Text
  attachmentKeys  String[]     @map("attachment_keys")
  isRead          Boolean      @default(false) @map("is_read")
  readAt          DateTime?    @map("read_at")
  createdAt       DateTime     @default(now()) @map("created_at")

  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender          User         @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  recipient       User?        @relation("ReceivedMessages", fields: [recipientId], references: [id], onDelete: SetNull)

  @@index([conversationId, createdAt])
  @@index([senderId])
  @@map("messages")
}

// =============================
// NOTIFICATIONS
// =============================

model Notification {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  type      NotificationType
  title     String
  body      String           @db.Text
  data      Json?            // additional context: { dealId, campaignId, etc. }
  isRead    Boolean          @default(false) @map("is_read")
  readAt    DateTime?        @map("read_at")
  createdAt DateTime         @default(now()) @map("created_at")

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt(sort: Desc)])
  @@map("notifications")
}

enum NotificationType {
  NEW_APPLICATION
  APPLICATION_ACCEPTED
  APPLICATION_REJECTED
  NEW_DEAL
  DEAL_UPDATED
  DEAL_COMPLETED
  DELIVERABLE_SUBMITTED
  DELIVERABLE_APPROVED
  DELIVERABLE_REVISION
  PAYOUT_SENT
  PAYOUT_COMPLETED
  NEW_MESSAGE
  NEW_REVIEW
  CAMPAIGN_INVITE
  SYSTEM
}

// =============================
// PLATFORM REPORTS (admin analytics)
// =============================

model PlatformReport {
  id              String   @id @default(cuid())
  period          String   // e.g. "2026-03", "2026-W10"
  totalUsers      Int      @default(0) @map("total_users")
  totalCreators   Int      @default(0) @map("total_creators")
  totalBrands     Int      @default(0) @map("total_brands")
  totalCampaigns  Int      @default(0) @map("total_campaigns")
  totalDeals      Int      @default(0) @map("total_deals")
  totalGmv        Decimal  @default(0) @map("total_gmv") @db.Decimal(14, 2)
  totalFees       Decimal  @default(0) @map("total_fees") @db.Decimal(14, 2)
  data            Json?    // breakdown details
  createdAt       DateTime @default(now()) @map("created_at")

  @@unique([period])
  @@map("platform_reports")
}
